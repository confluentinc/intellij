<idea-plugin>
  <id>com.intellij.bigdatatools.kafka</id>
  <name>Kafka</name>
  <vendor>JetBrains</vendor>

  <description><![CDATA[
<p>The plugin lets you monitor your <a href="https://kafka.apache.org/">Kafka</a> event streaming processes.</p>

<p>You can:
<dl>
   <dd>- Connect to Kafka cluster</dd>
   <dd>- Produce and consume messages in different formats including Avro, Protobuf</dd>
   <dd>- Manage topics, and monitor consumer groups</dd>
   <dd>- Use Confluent Schema Registry and AWS Glue Schema Registry</dd>
</dl>
</p>

<p>This plugin is a part of the Big Data Tools plugin bundle.</p>
<p>
    <a href="https://info.jetbrains.com/data-engineering-communication-center.html">Subscribe to our News</a> |
    <a href="https://blog.jetbrains.com/big-data-tools">Read our Blog</a> |
    <a href="https://slack-bdt.mau.jetbrains.com">Join the Slack Community</a>
</p>
    ]]></description>

  <depends>com.intellij.modules.ultimate</depends>

  <depends>com.intellij.bigdatatools.core</depends>

  <extensions defaultExtensionNs="com.intellij">
    <dependencySupport kind="java" coordinate="org.apache.kafka:kafka_2.13" displayName="Kafka"/>
    <dependencySupport kind="java" coordinate="org.apache.kafka:kafka_2.12" displayName="Kafka"/>
    <dependencySupport kind="java" coordinate="org.apache.kafka:kafka-clients" displayName="Kafka"/>
    <dependencySupport kind="java" coordinate="io.confluent:kafka-schema-registry-client" displayName="Kafka"/>

    <dependencySupport kind="javascript" coordinate="npm:node-rdkafka" displayName="Kafka"/>
    <dependencySupport kind="javascript" coordinate="npm:kafkajs" displayName="Kafka"/>
    <dependencySupport kind="javascript" coordinate="npm:@kafkajs/confluent-schema-registry" displayName="Kafka"/>

    <dependencySupport kind="dotnet" coordinate="Confluent.Kafka" displayName="Kafka"/>
    <dependencySupport kind="dotnet" coordinate="AWSSDK.Kafka" displayName="Kafka"/>
    <dependencySupport kind="dotnet" coordinate="Confluent.SchemaRegistry" displayName="Kafka"/>

    <dependencySupport kind="python" coordinate="confluent-kafka" displayName="Kafka"/>
    <dependencySupport kind="python" coordinate="librdkafka" displayName="Kafka"/>
    <dependencySupport kind="python" coordinate="python-schema-registry-client" displayName="Kafka"/>
    <dependencySupport kind="python" coordinate="kafka-python" displayName="Kafka"/>
  </extensions>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceImplementation="com.jetbrains.bigdatatools.kafka.common.settings.KafkaConfigStorage"/>

    <applicationService serviceImplementation="com.jetbrains.bigdatatools.kafka.toolwindow.config.KafkaToolWindowSettings"/>
    <bigdatatools.bdiConnectionSettingProvider implementation="com.jetbrains.bigdatatools.kafka.settings.KafkaSettingsProvider"/>

    <statistics.counterUsagesCollector implementationClass="com.jetbrains.bigdatatools.kafka.statistics.KafkaUsagesCollector"/>

    <projectService serviceImplementation="com.jetbrains.bigdatatools.kafka.toolwindow.KafkaMonitoringToolWindowController"/>

    <toolWindow id="KafkaToolWindow" anchor="bottom" canCloseContents="true"
                icon="/icons/kafkaToolWindow.svg"
                factoryClass="com.jetbrains.bigdatatools.kafka.toolwindow.KafkaToolWindowFactory"/>

    <fileEditorProvider implementation="com.jetbrains.bigdatatools.kafka.common.editor.KafkaEditorProvider"/>
    <iconMapper mappingFile="KafkaIconMappings.json"/>
  </extensions>
</idea-plugin>