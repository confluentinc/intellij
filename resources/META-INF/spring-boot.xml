<idea-plugin>
    <extensions defaultExtensionNs="com.intellij">
        <microservices.gutters.mqLineMarkerActionsProvider
                implementation="io.confluent.intellijplugin.spring.KafkaLineMarkerActionsProvider"/>

        <codeInsight.lineMarkerProvider language="yaml"
                                        implementationClass="io.confluent.intellijplugin.spring.KafkaSpringBootConfigLineMarkers"/>
        <codeInsight.lineMarkerProvider language="Properties"
                                        implementationClass="io.confluent.intellijplugin.spring.KafkaSpringBootConfigLineMarkers"/>
    </extensions>
</idea-plugin>